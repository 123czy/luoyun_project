{
    "aliyun": {
        "characters": {
            "qiaoyun": "qiaoyun_id",
            "xiaoyun": "xiaoyun_id"
        }
    },
    "ecloud": {
        "Authorization": "ecloud_login_authorization",
        "wId": {
            "qiaoyun": "qiaoyun_wId"
        }
    },
    "mongodb": {
        "mongodb_ip": "127.0.0.1",
        "mongodb_port": "27017",
        "mongodb_name": "mymongo"
    },
    "liblib": {
        "AccessKey": "AccessKey",
        "SecretKey": "SecretKey"
    },
    "llm": {
        "provider": "ark"
    },
    "doubao_models": {
        "deepseek_r1": "xxx",
        "deepseek_v3.1": "xxx",
        "doubao_1.5_pro": "xxx",
        "doubao_1.6_pro": "xxx"
    },
    "openai_compatible": {
        "base_url": "https://api.siliconflow.cn/v1",
        "api_key_env": "SILICONFLOW_API_KEY",
        "api_key": ""
    },
    "siliconflow_models": {
        "deepseek_r1": "deepseek-ai/DeepSeek-R1",
        "deepseek_v3.1": "deepseek-ai/DeepSeek-V3",
        "doubao_1.5_pro": "Qwen/Qwen2.5-72B-Instruct",
        "doubao_1.6_pro": "Qwen/Qwen2.5-72B-Instruct"
    },
    "embedding": {
        "provider": "aliyun",
        "model": "BAAI/bge-m3"
    },
    "rerank": {
        "provider": "openai_compatible",
        "model": "BAAI/bge-reranker-v2-m3"
    },
    "tts": {
        "provider": "openai_compatible",
        "model": "FunAudioLLM/CosyVoice2-0.5B",
        "voice": "FunAudioLLM/CosyVoice2-0.5B:anna",
        "response_format": "wav",
        "speed": 1.0
    },
    "aliyun_asr": {
        "URL": "wss://nls-gateway-cn-shanghai.aliyuncs.com/ws/v1",
        "APPKEY": "APPKEY"
    },
    "admin_user_id": "admin_user_id",
    "x": {
        "api_key": "your_x_api_key",
        "api_secret": "your_x_api_secret",
        "access_token": "your_x_access_token",
        "access_token_secret": "your_x_access_token_secret",
        "character_name": "qiaoyun",
        "input_mode": "poll",
        "webhook_host": "0.0.0.0",
        "webhook_port": 8081,
        "webhook_path": "/x/webhook",
        "webhook_public_url": "https://your-domain.com/x/webhook",
        "environment_name": "development",
        "enable_poll_fallback": false,
        "poll_interval_seconds": 30
    },
    "characters": {
        "qiaoyun": "qiaoyun_id",
        "xiaoyun": "xiaoyun_id"
    }
}
